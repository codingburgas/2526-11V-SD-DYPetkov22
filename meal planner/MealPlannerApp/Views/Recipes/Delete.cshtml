@model MealPlannerApp.Dtos.Recipes.RecipeDto
@* Shows recipe delete confirmation. *@
@{
    ViewData["Title"] = "Delete Recipe";
}

<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        Delete Recipe
    </div>
    <div class="card-body">
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <p class="text-muted mb-0">Owners can delete approved recipes too, but recipes already used in meal plans or shared templates still cannot be removed.</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3 d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
</form>
