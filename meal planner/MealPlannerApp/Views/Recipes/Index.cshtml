@model IEnumerable<MealPlannerApp.Dtos.Recipes.RecipeDto>
@* Lists visible recipes with filters. *@
@{
    ViewData["Title"] = "Recipes";
    var currentUserId = User.Identity?.IsAuthenticated == true ? User.GetRequiredUserId() : -1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Recipes</h1>
        <p class="text-muted mb-0">Approved recipes are public. Your drafts and submissions stay visible only to you and admins until approved.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">Create Recipe</a>
    }
</div>

<form asp-action="Index" method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Ingredient</label>
            <input type="text" name="ingredientName" value="@ViewData["IngredientName"]" class="form-control" placeholder="e.g. Rice" />
        </div>
        <div class="col-md-2 form-check">
            <input class="form-check-input" type="checkbox" name="vegetarianOnly" value="true" @(Convert.ToBoolean(ViewData["VegetarianOnly"]) ? "checked" : "") />
            <label class="form-check-label">Vegetarian</label>
        </div>
        <div class="col-md-3 form-check">
            <input class="form-check-input" type="checkbox" name="highProteinOnly" value="true" @(Convert.ToBoolean(ViewData["HighProteinOnly"]) ? "checked" : "") />
            <label class="form-check-label">High-Protein</label>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">Apply Filters</button>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Name</th>
            <th>Owner</th>
            <th>Status</th>
            <th>Cook Time</th>
            <th>Calories</th>
            <th class="text-end">Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var recipe in Model)
        {
            var isOwner = recipe.OwnerId == currentUserId;
            <tr>
                <td>
                    <div class="fw-semibold">@recipe.Name</div>
                    @if (recipe.ApprovalStatus != ApprovalStatus.Approved)
                    {
                        <div class="small text-muted">Private until approved</div>
                    }
                </td>
                <td>@recipe.OwnerUserName</td>
                <td>
                    <span class="badge @GetBadgeClass(recipe.ApprovalStatus)">@recipe.ApprovalStatus</span>
                </td>
                <td>@recipe.CookingTime min</td>
                <td>@recipe.Calories kcal</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-sm btn-outline-info">Details</a>
                    @if (User.IsInRole(ApplicationRoles.Admin) || isOwner)
                    {
                        <a asp-action="Edit" asp-route-id="@recipe.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@recipe.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@functions {
    private static string GetBadgeClass(ApprovalStatus status)
    {
        return status switch
        {
            ApprovalStatus.Approved => "text-bg-success",
            ApprovalStatus.PendingReview => "text-bg-warning",
            ApprovalStatus.Rejected => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}
