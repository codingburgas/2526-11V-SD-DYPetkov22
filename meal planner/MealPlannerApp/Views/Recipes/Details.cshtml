@model MealPlannerApp.Dtos.Recipes.RecipeDto
@* Shows one recipe with ingredients and review state. *@
@{
    ViewData["Title"] = "Recipe Details";
    var isOwner = User.Identity?.IsAuthenticated == true && Model.OwnerId == User.GetRequiredUserId();
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <div>
            <h1 class="h5 mb-0">@Model.Name</h1>
            <div class="small text-muted">Created by @Model.OwnerUserName</div>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-@(Model.IsVegetarian ? "success" : "secondary")">@(Model.IsVegetarian ? "Vegetarian" : "Non-Vegetarian")</span>
            <span class="badge @GetBadgeClass(Model.ApprovalStatus)">@Model.ApprovalStatus</span>
        </div>
    </div>
    <div class="card-body">
        <p class="mb-3">@Model.Description</p>
        <dl class="row mb-0">
            <dt class="col-sm-3">Cooking Time</dt>
            <dd class="col-sm-9">@Model.CookingTime min</dd>
            <dt class="col-sm-3">Calories</dt>
            <dd class="col-sm-9">@Model.Calories kcal</dd>
        </dl>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ReviewNotes))
{
    <div class="alert alert-warning mt-3">
        <strong>Admin feedback:</strong> @Model.ReviewNotes
    </div>
}

<div class="row mt-3 g-3">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h6 mb-0">What You Need</h2>
            </div>
            <div class="card-body">
                @if (Model.Ingredients.Count == 0)
                {
                    <p class="mb-0 text-muted">No ingredients have been added for this recipe yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var ingredient in Model.Ingredients)
                        {
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span>@ingredient.Name</span>
                                <span class="text-muted">@ingredient.QuantityInGrams g</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                <h2 class="h6 mb-0">How To Cook It</h2>
            </div>
            <div class="card-body">
                @if (string.IsNullOrWhiteSpace(Model.Instructions))
                {
                    <p class="mb-0 text-muted">No cooking instructions have been added yet.</p>
                }
                else
                {
                    <p class="mb-0" style="white-space: pre-line;">@Model.Instructions</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex flex-wrap gap-2">
    @if (User.Identity?.IsAuthenticated == true && (User.IsInRole(ApplicationRoles.Admin) || isOwner))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
    }
    @if (isOwner && Model.ApprovalStatus != ApprovalStatus.PendingReview && Model.ApprovalStatus != ApprovalStatus.Approved)
    {
        <form asp-action="SubmitForReview" method="post" class="d-inline">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-success">Submit For Review</button>
        </form>
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

@functions {
    private static string GetBadgeClass(ApprovalStatus status)
    {
        return status switch
        {
            ApprovalStatus.Approved => "text-bg-success",
            ApprovalStatus.PendingReview => "text-bg-warning",
            ApprovalStatus.Rejected => "text-bg-danger",
            _ => "text-bg-secondary"
        };
    }
}
