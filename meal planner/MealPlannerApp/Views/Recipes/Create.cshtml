@model MealPlannerApp.Dtos.Recipes.RecipeDto
@* Shows the recipe create form. *@
@{
    ViewData["Title"] = "Create Recipe";
}

<h1 class="h3 mb-3">Create Recipe</h1>

<form asp-action="Create" method="post" class="card card-body">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Instructions" class="form-label">Cooking Instructions</label>
        <textarea asp-for="Instructions" class="form-control" rows="6" placeholder="Describe the cooking steps"></textarea>
        <span asp-validation-for="Instructions" class="text-danger"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="CookingTime" class="form-label"></label>
            <input asp-for="CookingTime" class="form-control" />
            <span asp-validation-for="CookingTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Calories" class="form-label"></label>
            <input asp-for="Calories" class="form-control" />
            <span asp-validation-for="Calories" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mt-3">
        <input asp-for="IsVegetarian" class="form-check-input" />
        <label asp-for="IsVegetarian" class="form-check-label"></label>
    </div>

    <div class="alert alert-light border mt-4 mb-0">
        <strong>Publishing flow:</strong> save a private draft first or submit directly for admin approval. Until approval, only you and admins can see it.
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" name="submitForReview" value="false" class="btn btn-outline-secondary">Save Draft</button>
        <button type="submit" name="submitForReview" value="true" class="btn btn-primary">Submit For Review</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
