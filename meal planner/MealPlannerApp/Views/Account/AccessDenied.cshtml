@{
    ViewData["Title"] = "Access Denied";
}

<div class="card border-warning shadow-sm auth-card">
    <div class="card-body">
        <h1 class="h3 mb-2">Access denied</h1>
        <p class="text-muted mb-4">Your account is signed in, but it does not have permission for that action.</p>
        <div class="d-flex gap-2">
            <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Back Home</a>
            <a class="btn btn-outline-secondary" asp-controller="MealPlans" asp-action="Weekly">Open My Planner</a>
        </div>
    </div>
</div>
